{
  "name": "bazar-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently -k -n \"vite,electron\" -c \"cyan,magenta\" \"vite\" \"wait-on http-get://127.0.0.1:5173 && electron .\"",
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "build": "vite build && electron-builder",
    "build:vite": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@ericblade/quagga2": "^1.12.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@rive-app/react-canvas": "^4.27.3",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "better-sqlite3": "^12.8.0",
    "bwip-js": "^4.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron-pos-printer": "^1.3.8",
    "frimousse": "^0.3.0",
    "fuse.js": "^7.1.0",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pdf-to-printer": "^5.6.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-barcode": "^1.6.1",
    "react-barcode-reader": "^0.0.2",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.72.0",
    "react-hotkeys-hook": "^5.2.4",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "tailwindcss": "^4.2.2",
    "vite": "^6.3.5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.saldosmonserrat.bazar",
    "productName": "Bazar Monserrat",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
